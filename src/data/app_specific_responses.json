// ==================== SMART RESPONSE SELECTOR ====================

/**
 * Advanced Meta Response Engine
 * Intelligently selects responses based on:
 * - User language preference
 * - Query depth (quick vs detailed)
 * - Technical knowledge level
 * - Conversation context
 */
export const getMetaResponse = (
  userMessage: string,
  context: {
    language_preference?: 'hindi' | 'english' | 'hinglish';
    detail_level?: 'quick' | 'detailed';
    technical_knowledge?: 'beginner' | 'intermediate' | 'advanced';
    first_interaction?: boolean;
    user_type?: 'student' | 'developer' | 'parent' | 'teacher';
  } = {}
) => {
  const normalizedMessage = userMessage.toLowerCase().trim();
  
  // Find matching category
  for (const metaInfo of META_RESPONSES_DB) {
    const matchFound = metaInfo.triggers.some(trigger => 
      normalizedMessage.includes(trigger.toLowerCase())
    );
    
    if (matchFound) {
      // Filter responses based on context
      let eligibleResponses = metaInfo.responses;
      
      // Language filtering
      if (context.language_preference) {
        eligibleResponses = eligibleResponses.filter(r =>
          r.language === context.language_preference
        );
      }
      
      // Detail level filtering
      if (context.detail_level === 'quick') {
        eligibleResponses = eligibleResponses.filter(r =>
          r.duration?.includes('30 sec') || r.duration?.includes('1 min')
        );
      }
      
      // Select best response
      const selectedResponse = eligibleResponses.length > 0
        ? eligibleResponses[0]
        : metaInfo.responses[0];
      
      // Get follow-up
      const followUp = metaInfo.follow_up_engine?.options?.[0]?.question || null;
      
      return {
        response: selectedResponse.text,
        language: selectedResponse.language,
        tone: selectedResponse.tone,
        followUp: followUp,
        category: metaInfo.category
      };
    }
  }
  
  return null;
};

/**
 * Legacy Format Export (Backward Compatibility)
 */
export const LEGACY_META_FORMAT = META_RESPONSES_DB.map(item => ({
  type: item.type,
  hindi_responses: item.responses
    .filter(r => r.language === 'hindi' || r.language === 'hinglish')
    .map(r => r.text),
  english_responses: item.responses
    .filter(r => r.language === 'english')
    .map(r => r.text)
}));